-- Revive Self
local function ReviveSelf()
    local char = LocalPlayer.Character
    if char and char:GetAttribute("Downed") == true then
        local events = ReplicatedStorage:FindFirstChild("Events")
        if events and events.Player and events.Player.ChangePlayerMode then
            pcall(function()
                events.Player.ChangePlayerMode:FireServer(true)
            end)
            return true
        end
    end
    return false
end

-- Revive Other Player (SỬA LẠI)
local function RevivePlayer(player)
    if not player or player == LocalPlayer then return false end
    
    local char = player.Character
    if not char then return false end
    
    -- Kiểm tra xem player có đang downed không
    if char:GetAttribute("Downed") == true then
        local events = ReplicatedStorage:FindFirstChild("Events")
        if events then
            -- Cách 1: Dùng Interact event (đúng cho Evade)
            local interact = events:FindFirstChild("Character") and events.Character:FindFirstChild("Interact")
            if interact and interact:IsA("RemoteEvent") then
                local success = false
                pcall(function()
                    interact:FireServer("Revive", true, player.Name)
                    success = true
                end)
                if success then return true end
            end
            
            -- Cách 2: Dùng Player.Revive (nếu có)
            local playerRevive = events:FindFirstChild("Player") and events.Player:FindFirstChild("Revive")
            if playerRevive and playerRevive:IsA("RemoteEvent") then
                local success = false
                pcall(function()
                    playerRevive:FireServer(player)
                    success = true
                end)
                if not success then
                    pcall(function()
                        playerRevive:FireServer(player.Name)
                        success = true
                    end)
                end
                if success then return true end
            end
            
            -- Cách 3: Dùng ChangePlayerMode với argument đúng
            local changeMode = events:FindFirstChild("Player") and events.Player:FindFirstChild("ChangePlayerMode")
            if changeMode and changeMode:IsA("RemoteEvent") then
                local success = false
                pcall(function()
                    changeMode:FireServer(player)
                    success = true
                end)
                if not success then
                    pcall(function()
                        changeMode:FireServer(player.Name)
                        success = true
                    end)
                end
                if success then return true end
            end
        end
    end
    return false
end

-- Scan and Revive All Players (SỬA LẠI)
local function ScanAndReviveAll()
    local revivedCount = 0
    local players = Players:GetPlayers()
    
    for _, player in pairs(players) do
        if player ~= LocalPlayer then
            local char = player.Character
            if char and char:IsA("Model") then
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                local isDowned = char:GetAttribute("Downed")
                local health = humanoid and humanoid.Health or 0
                
                -- Nếu đang downed hoặc health <= 0
                if isDowned == true or health <= 0 then
                    local success = RevivePlayer(player)
                    if success then
                        revivedCount = revivedCount + 1
                        task.wait(0.1)
                    end
                end
            end
        end
    end
    return revivedCount
end

-- ESP Functions
local function CreateESP(character, color, text, parentPart, yOffset)
    if not character or not parentPart or not parentPart:IsA("BasePart") then return end
    if character:FindFirstChild("ESP_Highlight") then return end

    -- Highlight
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.Adornee = character
    highlight.FillColor = color
    highlight.FillTransparency = 0.4
    highlight.OutlineColor = color
    highlight.OutlineTransparency = 0.2
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = character

    -- Billboard
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP_Billboard"
    billboard.Size = UDim2.new(0, 120, 0, 40)
    billboard.AlwaysOnTop = true
    billboard.StudsOffset = Vector3.new(0, yOffset or 2, 0)
    billboard.Adornee = parentPart
    billboard.Parent = parentPart

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = tostring(text) or ""
    label.TextColor3 = color
    label.TextScaled = true
    label.Font = Enum.Font.GothamBold
    label.Parent = billboard

    -- Distance updater
    task.spawn(function()
        local cam = Workspace.CurrentCamera
        while highlight.Parent and billboard.Parent and parentPart.Parent and cam do
            local dist = (cam.CFrame.Position - parentPart.Position).Magnitude
            if Config.EspDistance then
                label.Text = tostring(text) .. " (" .. math.floor(dist) .. "m)"
            else
                label.Text = tostring(text)
            end
            task.wait(0.15)
        end
        highlight:Destroy()
        billboard:Destroy()
    end)
end

local function RemoveESP(character, parentPart)
    if character then
        local h = character:FindFirstChild("ESP_Highlight")
        if h then h:Destroy() end
    end
    if parentPart then
        local b = parentPart:FindFirstChild("ESP_Billboard")
        if b then b:Destroy() end
    end
end

-- Lighting Functions
local function SetFullBright(enabled)
    if enabled then
        Lighting.Brightness = 2
        Lighting.OutdoorAmbient = Color3.new(1, 1, 1)
        Lighting.Ambient = Color3.new(1, 1, 1)
        Lighting.GlobalShadows = false
    else
        Lighting.Brightness = OriginalLighting.Brightness
        Lighting.OutdoorAmbient = OriginalLighting.OutdoorAmbient
        Lighting.Ambient = OriginalLighting.Ambient
        Lighting.GlobalShadows = OriginalLighting.GlobalShadows
    end
end

local function SetSuperBright(enabled)
    if enabled then
        Lighting.Brightness = 15
        Lighting.OutdoorAmbient = Color3.new(1, 1, 1)
        Lighting.Ambient = Color3.new(1, 1, 1)
        Lighting.GlobalShadows = false
    else
        SetFullBright(Config.FullBright)
    end
end

local function SetNoFog(enabled)
    if enabled then
        Lighting.FogEnd = 1000000
        Lighting.FogStart = 999999
    else
        Lighting.FogEnd = OriginalLighting.FogEnd
        Lighting.FogStart = OriginalLighting.FogStart
    end
end

local function SetVibrant(enabled)
    if enabled then
        Lighting.ColorCorrection.Enabled = true
        Lighting.ColorCorrection.Saturation = 0.8
        Lighting.ColorCorrection.Contrast = 0.4
    else
        Lighting.ColorCorrection.Enabled = OriginalLighting.ColorCorrectionEnabled
        Lighting.ColorCorrection.Saturation = OriginalLighting.Saturation
        Lighting.ColorCorrection.Contrast = OriginalLighting.Contrast
    end
end

