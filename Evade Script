-- Ticket ESP
local function CreateTicketESP(obj)
    if ESP_Table[obj] then return end
    
    local h = Instance.new("Highlight")
    h.Name = "TicketESP_Highlight"
    h.Adornee = obj
    h.FillColor = Color3.fromRGB(255, 200, 0)
    h.FillTransparency = 0.5
    h.OutlineColor = Color3.fromRGB(255, 200, 0)
    h.OutlineTransparency = 0
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Enabled = true
    h.Parent = obj
    
    local bb = Instance.new("BillboardGui")
    bb.Name = "TicketESP_Billboard"
    bb.Size = UDim2.new(0, 60, 0, 20)
    bb.AlwaysOnTop = true
    bb.StudsOffset = Vector3.new(0, 2, 0)
    bb.Parent = obj
    
    local t = Instance.new("TextLabel")
    t.Size = UDim2.new(1, 0, 1, 0)
    t.BackgroundTransparency = 1
    t.Text = "🎫 TICKET"
    t.TextColor3 = Color3.fromRGB(255, 200, 0)
    t.TextScaled = true
    t.Font = Enum.Font.GothamBold
    t.Parent = bb
    
    local l = Drawing.new("Line")
    l.Visible = false
    l.Color = Color3.fromRGB(255, 200, 0)
    l.Thickness = 1
    
    ESP_Table[obj] = {Line = l, Highlight = h, Billboard = bb, Part = obj}
    
    obj.AncestryChanged:Connect(function(_, p)
        if not p then RemoveTicketESP(obj) end
    end)
end

local function RemoveTicketESP(obj)
    if ESP_Table[obj] then
        if ESP_Table[obj].Line then ESP_Table[obj].Line:Remove() end
        if ESP_Table[obj].Highlight then ESP_Table[obj].Highlight:Destroy() end
        if ESP_Table[obj].Billboard then ESP_Table[obj].Billboard:Destroy() end
        ESP_Table[obj] = nil
    end
end

-- Get Screen Edge Position cho Line ESP
local function GetScreenEdgePosition(center, dir, vpSize, offset)
    local halfX = (vpSize.X / 2) - offset
    local halfY = (vpSize.Y / 2) - offset
    local slope = dir.Y / dir.X
    local factor = math.min(halfX / math.abs(dir.X), halfY / math.abs(dir.Y))
    return center + (dir * factor)
end

-- Auto Farm Loop (Safe Zone)
local function StartAutoFarm()
    if Connections.AutoFarm then
        Connections.AutoFarm:Disconnect()
        Connections.AutoFarm = nil
    end
    
    CreateSafePlatform()
    
    Connections.AutoFarm = RunService.Heartbeat:Connect(function()
        if not Config.AutoFarm then return end
        
        local char = LocalPlayer.Character
        if not char then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        -- Tìm ticket
        local targetTicket = nil
        if TicketFolder then
            for _, v in ipairs(TicketFolder:GetDescendants()) do
                if v:IsA("BasePart") and v.Parent then
                    targetTicket = v
                    break
                end
            end
        end
        
        if targetTicket then
            -- Teleport đến ticket
            hrp.CFrame = targetTicket.CFrame + Vector3.new(0, 2, 0)
            task.wait(0.35)
            
            -- Quay về Safe Zone
            if SafePlatform then
                hrp.CFrame = CFrame.new(Vector3.new(0, 5000, 0) + Vector3.new(0, 3, 0))
            end
            task.wait(0.1)
        else
            -- Không có ticket -> đứng ở Safe Zone
            if SafePlatform then
                if (hrp.Position - Vector3.new(0, 5000, 0)).Magnitude > 50 then
                    hrp.CFrame = CFrame.new(Vector3.new(0, 5000, 0) + Vector3.new(0, 3, 0))
                end
            end
        end
    end)
end

local function StopAutoFarm()
    if Connections.AutoFarm then
        Connections.AutoFarm:Disconnect()
        Connections.AutoFarm = nil
    end
    RemoveSafePlatform()
end

