-- Revive Self
local function ReviveSelf()
    local char = LocalPlayer.Character
    if char and char:GetAttribute("Downed") == true then
        local events = ReplicatedStorage:FindFirstChild("Events")
        if events and events.Player and events.Player.ChangePlayerMode then
            pcall(function()
                events.Player.ChangePlayerMode:FireServer(true)
            end)
            return true
        end
    end
    return false
end

-- Revive Other Player
local function RevivePlayer(player)
    if not player or player == LocalPlayer then return false end
    
    local char = player.Character
    if not char then return false end
    
    if char:GetAttribute("Downed") == true then
        local events = ReplicatedStorage:FindFirstChild("Events")
        if events then
            local interact = events:FindFirstChild("Character") and events.Character:FindFirstChild("Interact")
            if interact and interact:IsA("RemoteEvent") then
                local success = false
                pcall(function()
                    interact:FireServer("Revive", true, player.Name)
                    success = true
                end)
                if success then return true end
            end
            
            local playerRevive = events:FindFirstChild("Player") and events.Player:FindFirstChild("Revive")
            if playerRevive and playerRevive:IsA("RemoteEvent") then
                local success = false
                pcall(function()
                    playerRevive:FireServer(player)
                    success = true
                end)
                if not success then
                    pcall(function()
                        playerRevive:FireServer(player.Name)
                        success = true
                    end)
                end
                if success then return true end
            end
            
            local changeMode = events:FindFirstChild("Player") and events.Player:FindFirstChild("ChangePlayerMode")
            if changeMode and changeMode:IsA("RemoteEvent") then
                local success = false
                pcall(function()
                    changeMode:FireServer(player)
                    success = true
                end)
                if not success then
                    pcall(function()
                        changeMode:FireServer(player.Name)
                        success = true
                    end)
                end
                if success then return true end
            end
        end
    end
    return false
end

-- Scan and Revive All Players
local function ScanAndReviveAll()
    local revivedCount = 0
    local players = Players:GetPlayers()
    
    for _, player in pairs(players) do
        if player ~= LocalPlayer then
            local char = player.Character
            if char and char:IsA("Model") then
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                local isDowned = char:GetAttribute("Downed")
                local health = humanoid and humanoid.Health or 0
                
                if isDowned == true or health <= 0 then
                    local success = RevivePlayer(player)
                    if success then
                        revivedCount = revivedCount + 1
                        task.wait(0.1)
                    end
                end
            end
        end
    end
    return revivedCount
end

